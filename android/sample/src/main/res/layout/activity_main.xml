<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9F9F9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Besitos SDK"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Parameter Control Panel"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="PARTNER ID (REQUIRED)" android:textSize="11sp" android:textColor="#2E45EF"
            android:textStyle="bold" android:layout_marginBottom="4dp" />
        <EditText
            android:id="@+id/etPartnerId"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:hint="CwI606dZ"
            android:text="CwI606dZ"
            android:inputType="text"
            android:background="@drawable/input_bg"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="16dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="USER ID (REQUIRED)" android:textSize="11sp" android:textColor="#2E45EF"
            android:textStyle="bold" android:layout_marginBottom="4dp" />
        <EditText
            android:id="@+id/etUserId"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:hint="user_123"
            android:text="user_123"
            android:inputType="text"
            android:background="@drawable/input_bg"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="16dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="SUB ID" android:textSize="11sp" android:textColor="#2E45EF"
            android:textStyle="bold" android:layout_marginBottom="4dp" />
        <EditText
            android:id="@+id/etSubId"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:hint="tracking_001"
            android:inputType="text"
            android:background="@drawable/input_bg"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="16dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="DEVICE ID" android:textSize="11sp" android:textColor="#2E45EF"
            android:textStyle="bold" android:layout_marginBottom="4dp" />
        <EditText
            android:id="@+id/etDeviceId"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:hint="optional"
            android:inputType="text"
            android:background="@drawable/input_bg"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="16dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="EXTRA INFO" android:textSize="11sp" android:textColor="#2E45EF"
            android:textStyle="bold" android:layout_marginBottom="4dp" />
        <EditText
            android:id="@+id/etInfo"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:hint="JSON or string data"
            android:inputType="text"
            android:background="@drawable/input_bg"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Hide Header"
                android:textSize="13sp"
                android:textColor="#1A1A1A"
                android:textStyle="bold"
                android:gravity="center_vertical" />
            <Switch
                android:id="@+id/swHideHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:layout_marginEnd="16dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Hide Footer"
                android:textSize="13sp"
                android:textColor="#1A1A1A"
                android:textStyle="bold"
                android:gravity="center_vertical" />
            <Switch
                android:id="@+id/swHideFooter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />
        </LinearLayout>

        <Button
            android:id="@+id/btnLaunch"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="LAUNCH WITH CONFIG"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="17sp"
            android:letterSpacing="0.05"
            android:backgroundTint="#EF0000"
            android:stateListAnimator="@null" />

    </LinearLayout>
</ScrollView>
