{
  "name": "besitos-react-native-sdk-offerwall",
  "version": "1.0.1",
  "description": "Besitos Offerwall Mobile SDK for React Native and Expo",
  "main": "react-native/lib/index.js",
  "module": "react-native/lib/index.js",
  "types": "react-native/lib/index.d.ts",
  "source": "react-native/src/index.ts",
  "files": [
    "react-native.config.js",
    "react-native/src",
    "react-native/lib",
    "react-native/android",
    "react-native/ios",
    "react-native/OfferwallRN.podspec",
    "android/besitos-android-sdk",
    "ios/Sources/Offerwall",
    "ios/Offerwall.podspec",
    "ios/Package.swift",
    "README.md",
    "LICENSE",
    "!react-native/android/build",
    "!react-native/ios/build",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "build": "tsc --project react-native/tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "typescript": "tsc --noEmit --project react-native/tsconfig.json",
    "lint": "eslint \"**/*.{js,ts,tsx}\""
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "besitos",
    "offerwall"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/KashKick/besitos-react-native-sdk.git"
  },
  "homepage": "https://github.com/KashKick/besitos-react-native-sdk#readme",
  "bugs": {
    "url": "https://github.com/KashKick/besitos-react-native-sdk/issues"
  },
  "author": "KashKick <shraddha@kashkick.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react-native": ">=0.73.0"
  },
  "react-native": {
    "platforms": {
      "android": {
        "sourceDir": "react-native/android"
      },
      "ios": {
        "project": "react-native/OfferwallRN.podspec"
      }
    }
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
